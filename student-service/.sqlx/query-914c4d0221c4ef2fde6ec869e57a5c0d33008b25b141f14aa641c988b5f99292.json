  "query": "\n        UPDATE students\n        SET\n            name = COALESCE($2, name),\n            email = COALESCE($3, email),\n            updated_at = NOW()\n        WHERE uuid = $1\n          AND deleted_at IS NULL\n        RETURNING *\n        ",
